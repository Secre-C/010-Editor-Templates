typedef enum<u8>
{
    D3D10_SB_OPERAND_0_COMPONENT = 0,
    D3D10_SB_OPERAND_1_COMPONENT = 1,
    D3D10_SB_OPERAND_4_COMPONENT = 2,
    D3D10_SB_OPERAND_N_COMPONENT = 3 // unused for now
} D3D10_SB_OPERAND_NUM_COMPONENTS;

typedef enum<u8>
{
    D3D10_SB_OPERAND_TYPE_TEMP           = 0,  // Temporary Register File
    D3D10_SB_OPERAND_TYPE_INPUT          = 1,  // General Input Register File
    D3D10_SB_OPERAND_TYPE_OUTPUT         = 2,  // General Output Register File
    D3D10_SB_OPERAND_TYPE_INDEXABLE_TEMP = 3,  // Temporary Register File (indexable)
    D3D10_SB_OPERAND_TYPE_IMMEDIATE32    = 4,  // 32bit/component immediate value(s)
                                          // If for example, operand token bits
                                          // [01:00]==D3D10_SB_OPERAND_4_COMPONENT,
                                          // this means that the operand type:
                                          // D3D10_SB_OPERAND_TYPE_IMMEDIATE32
                                          // results in 4 additional 32bit
                                          // DWORDS present for the operand.
    D3D10_SB_OPERAND_TYPE_IMMEDIATE64    = 5,  // 64bit/comp.imm.val(s)HI:LO
    D3D10_SB_OPERAND_TYPE_SAMPLER        = 6,  // Reference to sampler state
    D3D10_SB_OPERAND_TYPE_RESOURCE       = 7,  // Reference to memory resource (e.g. texture)
    D3D10_SB_OPERAND_TYPE_CONSTANT_BUFFER= 8,  // Reference to constant buffer
    D3D10_SB_OPERAND_TYPE_IMMEDIATE_CONSTANT_BUFFER= 9,  // Reference to immediate constant buffer
    D3D10_SB_OPERAND_TYPE_LABEL          = 10, // Label
    D3D10_SB_OPERAND_TYPE_INPUT_PRIMITIVEID = 11, // Input primitive ID
    D3D10_SB_OPERAND_TYPE_OUTPUT_DEPTH   = 12, // Output Depth
    D3D10_SB_OPERAND_TYPE_NULL           = 13, // Null register, used to discard results of operations
                                               // Below Are operands new in DX 10.1
    D3D10_SB_OPERAND_TYPE_RASTERIZER     = 14, // DX10.1 Rasterizer register, used to denote the depth/stencil and render target resources
    D3D10_SB_OPERAND_TYPE_OUTPUT_COVERAGE_MASK = 15, // DX10.1 PS output MSAA coverage mask (scalar)
                                               // Below Are operands new in DX 11
    D3D11_SB_OPERAND_TYPE_STREAM         = 16, // Reference to GS stream output resource
    D3D11_SB_OPERAND_TYPE_FUNCTION_BODY  = 17, // Reference to a function definition
    D3D11_SB_OPERAND_TYPE_FUNCTION_TABLE = 18, // Reference to a set of functions used by a class
    D3D11_SB_OPERAND_TYPE_INTERFACE      = 19, // Reference to an interface
    D3D11_SB_OPERAND_TYPE_FUNCTION_INPUT = 20, // Reference to an input parameter to a function
    D3D11_SB_OPERAND_TYPE_FUNCTION_OUTPUT = 21, // Reference to an output parameter to a function
    D3D11_SB_OPERAND_TYPE_OUTPUT_CONTROL_POINT_ID = 22, // HS Control Point phase input saying which output control point ID this is
    D3D11_SB_OPERAND_TYPE_INPUT_FORK_INSTANCE_ID = 23, // HS Fork Phase input instance ID
    D3D11_SB_OPERAND_TYPE_INPUT_JOIN_INSTANCE_ID = 24, // HS Join Phase input instance ID
    D3D11_SB_OPERAND_TYPE_INPUT_CONTROL_POINT = 25, // HS Fork+Join, DS phase input control points (array of them)
    D3D11_SB_OPERAND_TYPE_OUTPUT_CONTROL_POINT = 26, // HS Fork+Join phase output control points (array of them)
    D3D11_SB_OPERAND_TYPE_INPUT_PATCH_CONSTANT = 27, // DS+HSJoin Input Patch Constants (array of them)
    D3D11_SB_OPERAND_TYPE_INPUT_DOMAIN_POINT = 28, // DS Input Domain point
    D3D11_SB_OPERAND_TYPE_THIS_POINTER       = 29, // Reference to an interface this pointer
    D3D11_SB_OPERAND_TYPE_UNORDERED_ACCESS_VIEW = 30, // Reference to UAV u#
    D3D11_SB_OPERAND_TYPE_THREAD_GROUP_SHARED_MEMORY = 31, // Reference to Thread Group Shared Memory g#
    D3D11_SB_OPERAND_TYPE_INPUT_THREAD_ID = 32, // Compute Shader Thread ID
    D3D11_SB_OPERAND_TYPE_INPUT_THREAD_GROUP_ID = 33, // Compute Shader Thread Group ID
    D3D11_SB_OPERAND_TYPE_INPUT_THREAD_ID_IN_GROUP = 34, // Compute Shader Thread ID In Thread Group
    D3D11_SB_OPERAND_TYPE_INPUT_COVERAGE_MASK = 35, // Pixel shader coverage mask input
    D3D11_SB_OPERAND_TYPE_INPUT_THREAD_ID_IN_GROUP_FLATTENED = 36, // Compute Shader Thread ID In Group Flattened to a 1D value.
    D3D11_SB_OPERAND_TYPE_INPUT_GS_INSTANCE_ID = 37, // Input GS instance ID
    D3D11_SB_OPERAND_TYPE_OUTPUT_DEPTH_GREATER_EQUAL = 38, // Output Depth, forced to be greater than or equal than current depth
    D3D11_SB_OPERAND_TYPE_OUTPUT_DEPTH_LESS_EQUAL    = 39, // Output Depth, forced to be less than or equal to current depth
    D3D11_SB_OPERAND_TYPE_CYCLE_COUNTER = 40, // Cycle counter
} D3D10_SB_OPERAND_TYPE;

typedef enum<u8>
{
    D3D10_SB_OPERAND_INDEX_0D = 0, // e.g. Position
    D3D10_SB_OPERAND_INDEX_1D = 1, // Most common.  e.g. Temp registers.
    D3D10_SB_OPERAND_INDEX_2D = 2, // e.g. Geometry Program Input registers.
    D3D10_SB_OPERAND_INDEX_3D = 3, // 3D rarely if ever used.
} D3D10_SB_OPERAND_INDEX_DIMENSION;

typedef enum<u8>
{
    D3D10_SB_OPERAND_4_COMPONENT_MASK_MODE    = 0,  // mask 4 components
    D3D10_SB_OPERAND_4_COMPONENT_SWIZZLE_MODE = 1,  // swizzle 4 components
    D3D10_SB_OPERAND_4_COMPONENT_SELECT_1_MODE = 2, // select 1 of 4 components
} D3D10_SB_OPERAND_4_COMPONENT_SELECTION_MODE;

// http://timjones.io/blog/archive/2015/09/02/parsing-direct3d-shader-bytecode
// https://github.com/tgjones/slimshader/blob/master/src/SlimShader/Chunks/Rdef/ResourceDefinitionChunk.cs

typedef struct {
    char signature[4];
    Assert(signature == "RD11", Str("[P5R_GSC] Incorrect RD11 header in RDEF chunk"));
    u32 Field04; // always 60
    u32 Field08; // always 24
    u32 Field0C; // always 32
    u32 Field10; // always 40
    u32 Field14; // always 36
    u32 Field18; // always 12
    u32 InterfaceSlotCount;
} RDEFRD11<read=Str("RD11 Chunk (SM5)")>;

typedef struct {
    u32 chunkLength;
    u32 bufferCount;
    u32 offsetToConstBuffer; // from beginning of chunk to first constant buffer
    u32 resourceBindCount;
    u32 offsetToResrcBindDesc; // from start of chunk to first resource binding description
    u8 minorVersion;
    u8 majorVersion;
    u16 programType<format=hex>;
    u32 Flags;
    u32 offsetToCreator; // start of chunk to "creator"
} RDEFHeader<size=32, read=Str("v%d.%d, %d buffers, %d resource binds", majorVersion, minorVersion, bufferCount, resourceBindCount)>;

typedef struct(u32 chunkStart) {
    local u32 start = chunkStart;
    u32 offsetToBufferName;
    u32 variableCount;
    u32 offsetTo1stVariableDesc;
    u32 Flags2;
    u32 constBufferType;
} RDEFConstBuffer<read = GetRDEFConstBufferName, optimize=false>;

typedef struct(u32 chunkStart) {
    local u32 start = chunkStart;
    u32 offsetToVariableName;
    u32 offsetFromStartOfConstBuffer;
    u32 variableSize;
    u32 offsetToDefaultValue;
    u32 offsetToVariableType;
    u32 Field18;
    u32 Field1C;
    u32 Field20;
    u32 Field24;
    u32 Field28;
} RDEFVariableDescription<read = GetRDEFVariableName, size=40>;

typedef struct {
    D3D_SHADER_VARIABLE_CLASS variableClass;
    D3D_SHADER_VARIABLE_TYPE variableType;
    u16 matrixRows;
    u16 matrixColumns;
    u16 arrayElements;
    u16 structMembers;
    u16 byteOffsetTo1stMember;
} RDEFVariableType<optimize=false, read=Str("%s, %s, [%d x %d]", EnumToString(variableClass), EnumToString(variableType), matrixRows, matrixColumns)>;

typedef struct(u32 chunkStart) {
    local u32 start = chunkStart;
    u32 offsetToResrcBindName;
    u32 shaderInputType;
    u32 ResourceReturnType;
    u32 ResourceViewDimension;
    u32 NumOfSamples;
    u32 BindPoint;
    u32 BindCount;
    u32 ShaderInputFlags;
    Printf("Slot %d\t %s\n", BindPoint, ReadString(start + offsetToResrcBindName));
} RDEFResourceBind<optimize=false, read = GetRDEFResourceBindName>;

string GetRDEFConstBufferName(RDEFConstBuffer& constBuffer) {
    string name;
    name = ReadString(constBuffer.start + constBuffer.offsetToBufferName);
    return name;
}

string GetRDEFResourceBindName(RDEFResourceBind& resrcBind) {
    string name;
    //name = ReadString(resrcBind.start + resrcBind.offsetToResrcBindName);
    SPrintf(name, "%s, Slot %d", ReadString(resrcBind.start + resrcBind.offsetToResrcBindName), resrcBind.BindPoint);
    return name;
}

string GetRDEFVariableName(RDEFVariableDescription& varDesc) {
    string buffer;
    SPrintf(buffer, "%s", ReadString(varDesc.start + varDesc.offsetToVariableName));
    return buffer;
}

typedef struct {
    // RDEF Header
    local u32 chunkStart = FTell() + 4;
    RDEFHeader header;
    if (header.majorVersion >= 5) { // RD11
        RDEFRD11 RD11Chunk;
    }
    local int j;
    local int i;
    local u32 varDescPos;
    for (j = 0; j < header.bufferCount; j++) {
        // constant buffer
        FSeek(chunkStart + header.offsetToConstBuffer + (j * 24));
        RDEFConstBuffer constBuffer(chunkStart);
        FSeek(chunkStart + constBuffer.offsetTo1stVariableDesc);
        for (i = 0; i < constBuffer.variableCount; i++) {
            // variable description
            RDEFVariableDescription variableDesc(chunkStart);
            varDescPos = FTell();
            FSeek(chunkStart + variableDesc.offsetToVariableType);
            // variable type
            RDEFVariableType variableType;
            FSeek(varDescPos);
        }
    }
    // resource bind description
    local int k;
    for (k = 0; k < header.resourceBindCount; k++) {
        FSeek(chunkStart + header.offsetToResrcBindDesc + (k * 0x20));
        RDEFResourceBind resourceBind(chunkStart);
    }
    // creator
    FSeek(chunkStart + header.offsetToCreator);
    string creator;
} RDEFChunk<optimize=false>;

typedef struct(u32 chunkStart) {
    local u32 start = chunkStart;
    u32 offsetToElementName;
    u32 semanticIndex;
    u32 SysvalueType;
    u32 ComponentType;
    u32 Register;
    u8 Mask;
    u8 RWMask;
    local u32 currPos = FTell();
    FSeek(Align(currPos, 4));
    
} ISGNElement<optimize=false, read=GetISGNElementName>;

string GetISGNElementName(ISGNElement& ISGN) {
    string buffer;
    SPrintf( buffer, "%s, register %d", ReadString(ISGN.start + ISGN.offsetToElementName), ISGN.Register);
    return buffer;
}


typedef struct {
    u32 chunkLength;
    local u32 chunkStart = FTell();
    u32 elementCount;
    u32 Field0C;
    // Element Data
    ISGNElement elements(chunkStart)[elementCount];
    FSeek(chunkStart + chunkLength);
} ISGNChunk;

typedef struct {
    u8 minorVersion : 4;
    u8 majorVersion : 4;
} SHDRVersionNumber<read=Str("%d.%d", majorVersion, minorVersion)>;

typedef struct {
    BitfieldDisablePadding();
    D3D10_SB_OPCODE_TYPE OpcodeType : 11;
    u16 : 13;
    u8 length : 7;
    bool isOpcodeExtended : 1;
} SHDROpcodeToken0;

typedef struct {
    SHDROpcodeToken0 opCodeHeader;
    if (opCodeHeader.length > 1) {
        u32 opCodeContents[opCodeHeader.length - 1];
    }
} SHDRChunkOpcode<read=Str("%s", EnumToString(opCodeHeader.OpcodeType))>;

// VERY WIP
typedef struct {
    u32 chunkLength;
    local u32 chunkStart = FTell();
    SHDRVersionNumber version;
    u8 padding<hidden=true>;
    u16 programType;
    u32 dwordCount;
    
    local u32 currDwordCount;
    while (currDwordCount < dwordCount - 2) {
        SHDRChunkOpcode opcode;
        currDwordCount += (1 + opcode.opCodeHeader.length - 1);
    }
    FSeek(chunkStart + chunkLength);
    //u32 shaderCode[dwordCount - 2];
} SHDRChunk<optimize=false>;

typedef struct {
    u32 chunkLength;
    u32 Stats[37];
} STATChunk;

typedef struct {
    SetRandomBackColor();
    char chunkHeader[4];
    switch (chunkHeader) {
        case "RDEF": // Resource Definition
            RDEFChunk RDEF;
            break;
        case "ISGN": // ISGN - Input Signature
        case "OSGN": // OSGN - Output Signature
            ISGNChunk ISGN;
            break;
        case "SHEX": // SHEX - SM5 Shader
            SHDRChunk Shader;
            break;
        case "STAT": // STAT - Statistics
            STATChunk STAT;
            break;
        default:
            Assert(false, Str("[P5R_GSC] Unknown DirectX Bytecode Chunk Header Type %x", chunkHeader));
            break;
    
    }
    FSeek(Align( FTell(), 4));
} DXBCChunk<optimize=false, read=chunkHeader>;


typedef struct {
    LittleEndian();
    char Signature[4]; // DXBC
    u32 Checksum[4];
    u32 Field14;
    u32 ShaderSize;
    u32 ChunkCount;
    u32 ChunkIndex[ChunkCount];
    DXBCChunk Chunk[ChunkCount];
    BigEndian();
} DXBCShaderContainer;

typedef struct {
    u8 Data[80];
} TegraShaderProgramHeader;

typedef struct {
    enum<u32> {
        PixelPermutation = 0,
        VertexPermutation = 1,
    } PermutationType;
    string name;
    FSeek(Align( FTell(), 4));
} HNSHV002Permutation<optimize=false, read=Str("%s, %s", EnumToString(PermutationType), name)>;

typedef struct {
    u32 AllBlocksSize;
    u32 BlockSize0;
    DXBCShaderContainer FullShader;
    u32 BlockSize1;
    DXBCShaderContainer InputSignature;
    if (BlockSize0 + BlockSize1 + 16 < AllBlocksSize) {
        u32 BlockSize2;
        u8 ShaderNames[BlockSize2 - 8];
    }
    u32 EndOfChunk;
} HNSHV002ShaderBlockDX11Impl<optimize=false>;

typedef struct {
    u32 AllBlocksSize;
    u32 BlockSize0;
    FSkip(BlockSize0);
    u32 BlockSize1;
    FSkip(BlockSize1);
    if (BlockSize0 + BlockSize1 + 16 < AllBlocksSize) {
        u32 BlockSize2;
        FSkip(BlockSize2 - 8);
    }
    u32 EndOfChunk;
} HNSHV002ShaderBlockDefaultImpl<optimize=false>;

// partially based on https://github.com/Radfordhound/HedgeLib/blob/5e3cb21adb6efdfa097b625c8417eaaacd45fcfc/HedgeLib/src/shader/hl_hh_shader.cpp

typedef struct {
    char Signature[8]; // HNSHNV002
    local u32 chunkStart = FTell();
    u32 ChunkSize;
    u32 Field08;
    u32 PermutationCount;
    HNSHV002Permutation permutationCount[PermutationCount];
    u32 Field10;
    //u32 Field14;
    u32 unk1[1 << PermutationCount];
    while (FTell() < chunkStart + ChunkSize) {
        switch (platform) {
            case DX11: {
                if (!fastLoad) HNSHV002ShaderBlockDX11Impl shaderData;
                else HNSHV002ShaderBlockDefaultImpl shaderData;
                break;
            }
            //case Tegra: HNSHV002ShaderBlockMaxwellImpl shaderData; break;
            default: HNSHV002ShaderBlockDefaultImpl shaderData; break;
        }
    }
    /*
    while (FTell() < chunkStart2 + AllBlocksSize) {
    //while (FTell() < chunkStart + AllBlocksSize) {
        u32 BlockSize;
        switch (platform) {
            case DX11: DXBCShaderContainer Shader; break;
            case Tegra: FSkip(BlockSize); break;
            default: Assert(false, Str("[P5R_GSC] Unknown shader platform %d)", platform));
        }
        blockSizeVerify += BlockSize;
    }*/
    //Assert(blockSizeVerify + 16 == AllBlocksSize, Str("[P5R_GSC] Shader block list size does not match listed size (%d when shader list was %d)", AllBlocksSize, blockSizeVerify));
    //Assert(blockSizeVerify == AllBlocksSize, Str("[P5R_GSC] Shader block list size does not match listed size (%d when shader list was %d)", AllBlocksSize, blockSizeVerify));
    //u32 EndOfChunk;
} HNSHV002Chunk<size = (8 + ReadUInt(startof(this) + 8))>; // optimized struct, faster read time
//} HNSHV002Chunk<optimize=false>; // a lot slower, for debugging

typedef struct {
    char Signature[8]; // HHNEEDLE
    u32 BlockSize;
    string shaderCompileLogFile;
    //u8 Field4;
    FSeek(Align( FTell(), 4));
    SetRandomBackColor();
    HNSHV002Chunk HNSHV002;
} HHNEEDLEChunk;

// FUN_14026a230
typedef struct {
    char Signature[4]; // SVSV
    //u16 ShaderType; // loads differently if set to 0 vs 1 (SVSV uses 0, __SP uses 1)
    enum<u16> {
        Vertex = 0,
        Pixel = 1,
    } ShaderType;
    u32 InsideChunkSize;
    EShaderType shaderType;
    ShaderFlags shaderFlags;
    TMaterialMapsTexcoord texcoordFlag1;
    TMaterialMapsTexcoord texcoordFlag2;
    //if (Field04 == 0) {
    if (InsideChunkSize > 0) {
        SetRandomBackColor();
        HHNEEDLEChunk HHNEEDLE;
        Assert( InsideChunkSize == sizeof(HHNEEDLE), Str("[P5R_GSC] Internal Chunk did not match size reported in external chunk (%d, %d)", InsideChunkSize, sizeof(HHNEEDLE)));
    } else {
        /*
        SetRandomBackColor();
        HHNEEDLEChunk HHNEEDLE;
        */
    }
//} SVSVChunk<size = (ReadUInt(startof(this) + 6) + 36)>; // optimized struct, faster read time
} SVSVChunk<optimize=false, read=SVSVEntrySummary>; // for debugging

string SVSVEntrySummary(SVSVChunk& chunk) {
    string out;
    SPrintf(out, "%s_%x_%x_%x_%x_%x_%x_%x_%x", 
        EnumToString(chunk.shaderType), chunk.ShaderType, chunk.shaderType,
        chunk.shaderFlags.FLAG0, chunk.shaderFlags.FLAG1, chunk.shaderFlags.FLAG2, chunk.shaderFlags.FLAG3, 
        showMaterialTexcoord2(chunk.texcoordFlag1), showMaterialTexcoord2(chunk.texcoordFlag2)
    );
    return out;
}

typedef enum<u32> {
    DX11 = 7,
    Tegra = 8,
} GSCShaderType;

local string filePath = GetFileName();
local string fileName = FileNameGetBase(filePath, false);
local string fileExt = FileNameGetExtension(filePath);
local GSCShaderType platform = DX11;
local bool fastLoad = false;

if (Stricmp(fileExt, ".GSC") == 0 ) {
    SetRandomBackColor();
    TFileHeader GFSFileHeader;
    SetRandomBackColor();
    TFileHeader GSCFileHeader;
    platform = GSCFileHeader.Type;
    switch (platform) {
        case DX11: Printf("DirectX 11 shaders\n"); break;
        case Tegra: Printf("Tegra shaders\n"); break;
        default: Assert(false, Str("[P5R_GSC] Unknown shader platform %d)", platform));
    }
    local u32 chunkHeader;
    local u32 chunkCount = 0;
    while (!FEof()) {
        chunkHeader = ReadInt(FTell());
        SetRandomBackColor();
        switch (chunkHeader) {
            case 0x53565356:
                SVSVChunk SVSV;
                break;
            case 0x5f5f5350:
                SVSVChunk SP;
                break;
            default:
                Assert(false, Str("[P5R_GSC] Unknown SVSV Chunk Header Type %x", chunkHeader));
                break;
        }
        chunkCount++;
    }
    Printf("%d chunks\n", chunkCount);
} else {
    Assert(false, Str("[P5R_GSC] Incorrect File Extension %s\n", fileExt));
}