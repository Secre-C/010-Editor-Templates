//      File: p5r_gsc.bt
//   Authors: Rirurin
//   Version: v0.1.0
//   Purpose: Persona 5 Royal GFD Shader Cache Template
// File Mask: *.gsc
//  ID Bytes: GFS0
//   History:   v0.2.0 (2023/02/22) Defined SVSV Chunk fields, template now runs on Switch shader cache (not reading into compiled Maxwell shader code though!)
//              v0.1.0 (2022/12/03) Mapped basic layout of GSC and partial support for DX11 Bytecode
//------------------------------------------------

#include "common/include.h"
#include "p5_gfd_enums.bt"
#include "p5_gfd_enum_functions.bt"

BigEndian();

typedef struct
{
    char Signature[4];
    u32 Version <format=hex>;
    EFileType Type;
    u32 Reserved;
    Assert( Reserved == 0 );
} TFileHeader <read=TFileHeaderToString>;

string TFileHeaderToString( TFileHeader& value )
{
    string buffer;
    SPrintf( buffer, "%s, ver 0x%08X, type %d", value.Signature, value.Version, value.Type );
    return buffer;
}

// DIRECTX 11 TYPES

